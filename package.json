{
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-array-func": "^5.1.1",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^65.0.0",
    "typescript-eslint": "^8.60.1"
  },
  "description": "Safety-oriented, fp-first configuration of ESLint.",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.19.20",
    "commitizen": "^4.3.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "constants.js",
    "index.js",
    "jest.js",
    "jest-esm.js",
    "makeConfig.js",
    "vitest.js",
    "vitest-esm.js",
    "configs",
    "README.md"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{js,json,md,ts,yml,yaml}": [
      "prettier --write"
    ]
  },
  "exports": {
    ".": "./index.js",
    "./jest": "./jest.js",
    "./jest-esm": "./jest-esm.js",
    "./vitest": "./vitest.js",
    "./vitest-esm": "./vitest-esm.js"
  },
  "main": "./index.js",
  "name": "@ridedott/eslint-config",
  "peerDependencies": {
    "eslint": "^10.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:ridedott/eslint-config.git"
  },
  "scripts": {
    "clean": "rm -rf lib",
    "cz": "git-cz",
    "cz:retry": "git-cz --retry",
    "format": "prettier --check '**/*.{js,json,md,ts,yml,yaml}'",
    "format:fix": "prettier --write '**/*.{js,json,md,ts,yml,yaml}'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "version": "5.7.15"
}
